# Production environment for docker-compose.prod.yml.
#
#   cp .env.production.example .env.production   (on the server, NEVER commit)
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
#
# Connection strings (DATABASE_URL etc.) are composed inside
# docker-compose.prod.yml from the passwords below — don't set them here.

# ── Infrastructure credentials (generate strong values: `openssl rand -hex 24`)
POSTGRES_PASSWORD=
# Password for the RLS-enforced app role. After the FIRST boot, apply it inside
# Postgres too (the migration creates the role with a default password):
#   docker compose -f docker-compose.prod.yml exec postgres \
#     psql -U postgres -d subba -c "ALTER ROLE subba_app PASSWORD '<same value>'"
SUBBA_APP_PASSWORD=
RABBITMQ_PASSWORD=

# ── Domains
# API + webhooks are served at this domain (Caddy fetches TLS automatically).
API_DOMAIN=api.example.com
# Optional: uncomment the Grafana block in infra/caddy/Caddyfile to use this.
GRAFANA_DOMAIN=

# ── Application
LOG_LEVEL=info
# 32-byte AES-256 key (base64) for tenant-secret encryption: `openssl rand -base64 32`
# Changing it later makes previously encrypted secrets unreadable.
MASTER_ENCRYPTION_KEY=

# Public origins of the two frontends (Vercel custom domains). These feed CORS
# and the magic-link URLs — use SUBDOMAINS OF THE SAME DOMAIN as API_DOMAIN so
# session cookies (SameSite=Lax) survive cross-origin API calls.
PORTAL_BASE_URL=https://app.example.com/pay
DASHBOARD_BASE_URL=https://app.example.com

# ── Resend transactional email (sender domain needs SPF+DKIM+DMARC verified)
RESEND_API_KEY=
EMAIL_FROM_NAME=Subba
EMAIL_FROM_EMAIL=notify@example.com

# ── Nomba (LIVE credentials — only ever set on the server; rotate any key that
# was shared in chat before using it here)
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_ACCOUNT_ID=
NOMBA_SUBACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=

# ── Scheduler sweep cadence (e.g. 1m for demos, 1h steady-state)
SCHEDULER_INTERVAL=1m
