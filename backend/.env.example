# Copy to .env for local development. The app reads these on startup.

APP_ENV=development
LOG_LEVEL=debug
HTTP_ADDR=:8080

# Tenant-scoped connection: the `subba_app` role is NOT a superuser, so Postgres
# Row-Level Security is actually enforced on this connection. All end-user/tenant
# data access goes through here with `SET LOCAL app.tenant_id` per transaction.
# Note host port 5433: our Postgres container is remapped to avoid clashing with a
# system Postgres on 5432 (see docker-compose.yml).
DATABASE_URL=postgres://subba_app:subba_app@localhost:5433/subba?sslmode=disable

# Privileged connection: the `postgres` superuser bypasses RLS. Used only for
# migrations and tenant-agnostic operations (signup, auth, webhook→tenant routing).
ADMIN_DATABASE_URL=postgres://postgres:postgres@localhost:5433/subba?sslmode=disable

REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Public origin of the hosted customer portal; magic-link URLs are built from this.
PORTAL_BASE_URL=http://localhost:3000/pay

# Resend transactional email (portal magic links, receipts, dunning). The sender
# domain must have SPF + DKIM + DMARC verified in Resend or links land in spam.
RESEND_API_KEY=
EMAIL_FROM_NAME=Subba
EMAIL_FROM_EMAIL=notify@mail.subba.example

# Nomba integration (backend/engine only). Authenticate with the parent Account ID
# in the accountId header, then scope calls to the sub-account ID.
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_ACCOUNT_ID=
NOMBA_SUBACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
# Shared secret Nomba signs webhooks with (HMAC-SHA256).
NOMBA_WEBHOOK_SECRET=
